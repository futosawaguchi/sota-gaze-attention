# 設定は `.env` にコピーして実値を入れる（`.env` は gitignore 済み）。
#   cp .env.example .env

# --- Sota への UDP 送信（両モード共通）---
# 実機が無い検証では未設定でも可（SotaSender 既定 127.0.0.1:9980 へ＝無害）。
SOTA_IP=192.168.0.10
SOTA_PORT=9980

# --- THETA X 接続（all-local `--local` 時に必須）---
# gaze360 の ThetaStream が CWD の .env から読む。repo ルートで app.py を実行すること。
THETA_SERIAL=YN1xxxxx          # カメラのシリアル番号（必須）
THETA_IP=192.168.1.1           # CL モードでは実 IP（例 10.32.2.131）
THETA_PASSWORD=YN1xxxxx        # 省略時はシリアルと同じ

# --- 校正（任意・未設定は仮値の既定）。実機でズレたらここを直す（docs/calibration.md）---
# 取付オフセット（度）: 正面を見てるのに横/上を向く時に調整。
SOTA_YAW_OFFSET_DEG=0          # カメラ前方と Sota 正面の左右差
SOTA_PITCH_OFFSET_DEG=0        # 同・上下差
# 度→パルス係数: 大きいほど機敏（すぐ端に張り付く）/ 小さいほど鈍い。
SOTA_PULSE_PER_DEG_YAW=15.56   # 既定 1400/90（±1400↔±90°の仮定）
SOTA_PULSE_PER_DEG_PITCH=3.67  # 既定 110/30
# 符号: 左右/上下が逆に動く時に -1 にする。
SOTA_YAW_SIGN=1
SOTA_PITCH_SIGN=1
# 平滑化・ゲート。
SOTA_EMA_ALPHA=0.4             # 小=滑らか/遅い, 大=機敏/揺れる
SOTA_DEADBAND_DEG=2.0          # この未満の変化は送らない（カクつき防止）
SOTA_INOUT_MIN=0.3             # 視線がフレーム内の確率の下限（動かない時は下げる）

# --- 360°化（頭＋腰）。既定は無効＝頭のみ。腰の度↔パルス校正後に有効化する ---
SOTA_WAIST_ENABLED=0          # 1 で Waist_Y を使い後方まで体ごと向く
SOTA_PULSE_PER_DEG_WAIST=10   # 腰の度→パルス係数（既定 1200/120）
SOTA_HEAD_YAW_MAX_DEG=80      # 頭が担う最大ヨー（度）。超過分は腰へ
SOTA_WAIST_YAW_MAX_DEG=120    # 腰が担う最大ヨー（度）
SOTA_WAIST_SIGN=1             # 腰の回転が逆なら -1
